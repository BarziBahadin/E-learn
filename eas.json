{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_APP_MODE": "production",
        "EXPO_PUBLIC_ENABLE_DEMO_APP": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_APP_MODE": "production",
        "EXPO_PUBLIC_ENABLE_DEMO_APP": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_APP_MODE": "production",
        "EXPO_PUBLIC_ENABLE_DEMO_APP": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
